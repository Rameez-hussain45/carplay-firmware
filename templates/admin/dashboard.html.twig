{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block main %}
<div style="max-width:900px;">

    <h2 style="font-size:22px;font-weight:700;color:#0f172a;margin-bottom:6px;">
        Welcome to the Firmware Admin Panel
    </h2>
    <p style="color:#64748b;margin-bottom:32px;font-size:14px;">
        Use this panel to manage firmware versions shown on the CarPlay / Android Auto download page.
    </p>

    {# ── Quick action cards ───────────────────────────────────────────── #}
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;margin-bottom:36px;">

        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:24px;">
            <div style="font-size:30px;margin-bottom:10px;">📋</div>
            <h3 style="font-size:14px;font-weight:700;margin-bottom:6px;">All Versions</h3>
            <p style="font-size:13px;color:#64748b;margin-bottom:14px;">
                Browse, search and filter every firmware version entry.
            </p>
            <a href="{{ ea_url().setController('App\\Controller\\Admin\\SoftwareVersionCrudController').generateUrl() }}"
               style="display:inline-block;background:#1d4ed8;color:#fff;text-decoration:none;
                      border-radius:5px;padding:8px 18px;font-size:13px;font-weight:600;">
                Open List →
            </a>
        </div>

        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:24px;">
            <div style="font-size:30px;margin-bottom:10px;">➕</div>
            <h3 style="font-size:14px;font-weight:700;margin-bottom:6px;">Add New Version</h3>
            <p style="font-size:13px;color:#64748b;margin-bottom:14px;">
                Add a newly released firmware version so customers can download it.
            </p>
            <a href="{{ ea_url().setController('App\\Controller\\Admin\\SoftwareVersionCrudController').setAction('new').generateUrl() }}"
               style="display:inline-block;background:#1d4ed8;color:#fff;text-decoration:none;
                      border-radius:5px;padding:8px 18px;font-size:13px;font-weight:600;">
                Add Version →
            </a>
        </div>

        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:24px;">
            <div style="font-size:30px;margin-bottom:10px;">🔗</div>
            <h3 style="font-size:14px;font-weight:700;margin-bottom:6px;">Customer Page</h3>
            <p style="font-size:13px;color:#64748b;margin-bottom:14px;">
                View the live page customers use to get their download link.
            </p>
            <a href="/carplay/software-download" target="_blank"
               style="display:inline-block;background:#475569;color:#fff;text-decoration:none;
                      border-radius:5px;padding:8px 18px;font-size:13px;font-weight:600;">
                Open Page ↗
            </a>
        </div>

    </div>

    {# ── Step-by-step guide ───────────────────────────────────────────── #}
    <div style="background:#fefce8;border:1px solid #fde047;border-radius:10px;padding:24px;margin-bottom:24px;">
        <h3 style="font-size:15px;font-weight:700;color:#713f12;margin-bottom:14px;">
            📖 How to add a new firmware release — step by step
        </h3>
        <ol style="padding-left:20px;font-size:14px;color:#44403c;line-height:2.2;">
            <li>Click <strong>Add New Version</strong> above.</li>
            <li>Pick the correct <strong>Product Name</strong> from the dropdown
                (e.g. <em>MMI Prime CIC</em>).</li>
            <li>Enter the <strong>Software Version</strong> exactly as it appears in
                the customer's MMI — <strong>without a leading "v"</strong>
                (e.g. <code style="background:#f5f5f4;padding:1px 5px;border-radius:3px;">3.3.8.mmipri.c</code>).</li>
            <li>Paste the Google Drive download links:
                <ul style="margin-top:4px;padding-left:20px;line-height:1.8;">
                    <li><strong>ST Download Link</strong> — for CIC hardware (SanDisk flash). Leave blank for NBT/EVO.</li>
                    <li><strong>GD Download Link</strong> — for NBT and EVO hardware (GigaDevice flash). Leave blank for CIC.</li>
                </ul>
            </li>
            <li>Do <strong>not</strong> tick <em>Is Latest</em> yet. Click Save.</li>
            <li>Find the <em>previous</em> "Is Latest" entry for this product.
                Edit it → fill in its download links → <strong>untick Is Latest</strong> → Save.</li>
            <li>Return to your new entry → tick <strong>Is Latest</strong> → Save.</li>
            <li>Test on the customer page: enter an old version number and check the correct links appear.</li>
        </ol>
    </div>

    {# ── Warning banner ───────────────────────────────────────────────── #}
    <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:10px;padding:20px;">
        <h3 style="font-size:14px;font-weight:700;color:#b91c1c;margin-bottom:8px;">
            ⚠️ Wrong firmware links destroy customer hardware
        </h3>
        <p style="font-size:13px;color:#44403c;line-height:1.7;">
            Installing the wrong firmware on a customer's MMI unit can permanently damage it.
            Always verify that the download links you enter match the correct product and
            hardware type. If you are not sure, ask a developer to check.
        </p>
    </div>

</div>
{% endblock %}
