<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CarPlay / Android Auto MMI Software Update | BimmerTech</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Rubik', sans-serif;
            color: #212121;
            background: #f5f5f5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 16px 80px;
        }

        #software-download {
            width: 100%;
            max-width: 600px;
        }

        /* ── Title card ─────────────────────────────────────────────────── */
        .section-title {
            box-shadow: inset 2px 3px 5px #00000040, 2px 3px 5px #00000040;
            border: 1px solid #ffffff;
            border-radius: 20px;
            padding: 24px;
            max-width: 590px;
            margin: 0 auto 32px;
            background: #ffffff;
            text-align: center;
        }

        .section-title .title {
            font-size: 42px;
            line-height: 48px;
            letter-spacing: -0.48px;
            color: #212121;
            font-weight: 300;
        }

        .section-title .title .bold {
            display: block;
            font-size: 36px;
            letter-spacing: -0.36px;
            font-weight: 700;
        }

        /* ── Form card ──────────────────────────────────────────────────── */
        .card {
            background: #fff;
            border-radius: 8px;
            padding: 32px 24px 24px;
            box-shadow: 0 2px 8px rgba(0,0,0,.08);
            margin-bottom: 16px;
        }

        .form-row { margin-bottom: 16px; }

        .field-label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .5px;
            color: rgba(0,0,0,.54);
            margin-bottom: 4px;
            text-transform: uppercase;
        }

        .field-input {
            width: 100%;
            border: 1px solid rgba(0,0,0,.38);
            border-radius: 4px;
            padding: 10px 12px;
            font-size: 16px;
            font-family: 'Rubik', sans-serif;
            color: #212121;
            outline: none;
            transition: border-color .15s;
            background: #fff;
        }

        .field-input:focus {
            border-color: #1565c0;
            border-width: 2px;
            padding: 9px 11px;
        }

        .field-input.disabled {
            background: #f2f2f2;
            color: #aaa;
            cursor: not-allowed;
        }

        .field-error {
            color: #b71c1c;
            font-size: 12px;
            margin-top: 4px;
            display: none;
        }
        .field-error.show { display: block; }

        /* ── Button row ─────────────────────────────────────────────────── */
        .btn-row {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 24px;
        }

        .btn-check {
            background: #1976d2;
            color: #fff;
            border: none;
            border-radius: 4px;
            padding: 8px 22px;
            font-size: 14px;
            font-family: 'Rubik', sans-serif;
            font-weight: 500;
            letter-spacing: .8px;
            text-transform: uppercase;
            cursor: pointer;
            transition: background .15s, box-shadow .15s;
            box-shadow: 0 2px 4px rgba(0,0,0,.2);
        }
        .btn-check:hover  { background: #1565c0; box-shadow: 0 3px 6px rgba(0,0,0,.25); }
        .btn-check:active { background: #0d47a1; }
        .btn-check:disabled { opacity: .5; cursor: not-allowed; }

        /* ── Tooltip (info icon) ────────────────────────────────────────── */
        .tooltip-wrap { position: relative; display: inline-flex; align-items: center; }

        .tooltip-icon {
            width: 24px; height: 24px;
            border-radius: 50%;
            border: 1px solid #9e9e9e;
            color: #9e9e9e;
            font-size: 14px;
            display: flex; align-items: center; justify-content: center;
            cursor: help; user-select: none;
        }

        .tooltip-bubble {
            display: none;
            position: absolute;
            bottom: calc(100% + 8px);
            left: 50%;
            transform: translateX(-50%);
            width: 250px;
            background: rgba(0,0,0,.87);
            color: #fff;
            font-size: 12px;
            line-height: 1.5;
            padding: 10px 12px;
            border-radius: 4px;
            z-index: 50;
        }
        .tooltip-wrap:hover .tooltip-bubble { display: block; }

        /* ── Result alerts ──────────────────────────────────────────────── */
        .alert {
            margin-top: 16px;
            padding: 12px 16px;
            border-radius: 4px;
            font-size: 14px;
            line-height: 1.6;
        }

        .alert-success {
            background: #f6ffed;
            border: 1px solid #b7eb8f;
            color: #389e0d;
        }

        .alert-error {
            background: #fff1f0;
            border: 1px solid #ffa39e;
            color: #cf1322;
        }

        .download-link {
            display: inline-block;
            margin-left: 8px;
            color: #389e0d;
            font-size: 16px;
            font-weight: 500;
            text-transform: uppercase;
            text-decoration: underline;
        }

        /* ── "What is my software?" link ────────────────────────────────── */
        .info-link {
            display: block;
            text-align: center;
            margin-top: 14px;
            font-size: 14px;
            color: #1976d2;
            text-decoration: underline;
            cursor: pointer;
        }

        /* ── Warning box ─────────────────────────────────────────────────── */
        .warning-box {
            margin-top: 16px;
            padding: 14px 16px;
            background: #fff8e1;
            border-radius: 4px;
            font-size: 14px;
            line-height: 1.7;
            color: #212121;
        }
        .warning-box strong { display: block; margin-bottom: 6px; }

        /* ── Bottom card ─────────────────────────────────────────────────── */
        .bottom-card {
            background: #fff;
            border-radius: 8px;
            padding: 24px;
            box-shadow: 0 2px 8px rgba(0,0,0,.08);
            text-align: center;
        }

        .shop-btn {
            display: inline-block;
            background: #1976d2;
            color: #fff;
            text-decoration: none;
            border-radius: 4px;
            padding: 8px 22px;
            font-size: 14px;
            font-family: 'Rubik', sans-serif;
            font-weight: 500;
            letter-spacing: .8px;
            text-transform: uppercase;
        }
        .shop-btn:hover { background: #1565c0; }

        .legal-text {
            margin-top: 14px;
            font-size: 12px;
            color: #757575;
            line-height: 1.6;
        }

        /* ── Loading overlay on the form card ───────────────────────────── */
        .loading { position: relative; pointer-events: none; cursor: default; }
        .loading::before {
            content: '';
            position: absolute; inset: 0;
            background: rgba(255,255,255,.8);
            z-index: 10;
            border-radius: 8px;
        }
        .loading::after {
            content: '';
            position: absolute;
            top: 50%; left: 50%;
            width: 3em; height: 3em;
            margin: -1.5em 0 0 -1.5em;
            border-radius: 50%;
            border: .2em solid rgba(0,0,0,.1);
            border-top-color: #757575;
            animation: spin .6s linear infinite;
            z-index: 11;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Modal ───────────────────────────────────────────────────────── */
        .modal-overlay {
            display: none;
            position: fixed; inset: 0;
            background: rgba(0,0,0,.7);
            z-index: 200;
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.open { display: flex; }

        .modal-box {
            background: #fff;
            border-radius: 4px;
            overflow: hidden;
            max-width: 90vw;
            max-height: 90vh;
        }
        .modal-header {
            background: #000;
            display: flex;
            justify-content: flex-end;
            padding: 4px 8px;
        }
        .modal-close {
            background: none; border: none;
            color: #fff; font-size: 24px;
            cursor: pointer; line-height: 1;
            padding: 2px 8px;
        }
        .modal-box img {
            display: block;
            max-width: 80vw;
            max-height: 80vh;
            object-fit: contain;
        }

        /* ── Responsive ──────────────────────────────────────────────────── */
        @media (max-width: 767px) {
            .section-title .title       { font-size: 35px; line-height: 40px; }
            .section-title .title .bold { font-size: 27px; line-height: 40px; }
        }
    </style>
</head>
<body>

<div id="software-download">

    <!-- Title -->
    <div class="section-title">
        <h1 class="title">
            <span class="bold">Update the software for your</span>
            CarPlay / Android Auto MMI
        </h1>
    </div>

    <!-- Form card -->
    <div class="card" id="form-card">
        <form id="sw-form" novalidate autocomplete="off">

            <!-- Software Version -->
            <div class="form-row">
                <label class="field-label" for="version">Software Version</label>
                <input class="field-input" type="text" id="version"
                       placeholder="Your software version*" autocomplete="off">
                <div class="field-error" id="version-err">This field is required</div>
            </div>

            <!-- MCU Version (disabled — matches original exactly) -->
            <div class="form-row">
                <label class="field-label" for="mcuVersion">MCU Version Not Required</label>
                <input class="field-input disabled" type="text" id="mcuVersion"
                       placeholder="Not Required" disabled>
            </div>

            <!-- HW Version -->
            <div class="form-row">
                <label class="field-label" for="hwVersion">HW Version</label>
                <input class="field-input" type="text" id="hwVersion"
                       placeholder="Your HW version*" autocomplete="off">
                <div class="field-error" id="hwVersion-err">This field is required</div>
            </div>

            <!-- Submit + tooltip -->
            <div class="btn-row">
                <button type="submit" class="btn-check" id="check-btn">Check</button>
                <div class="tooltip-wrap">
                    <div class="tooltip-icon">i</div>
                    <div class="tooltip-bubble">
                        Enter your current software version to check if there is an update
                        available. You can find your current software in MMI settings &gt;
                        System &gt; System/firmware version.
                    </div>
                </div>
            </div>

            <!-- Result -->
            <div id="result" style="display:none;"></div>

            <!-- What is my software link -->
            <a class="info-link" id="open-modal">What is my current software?</a>

            <!-- Warning -->
            <div class="warning-box">
                <strong>Warning!!!</strong>
                Entering an incorrect software number and uploading it to another version of MMI
                will brick the MMI.<br>
                In most cases, this is a reversible process, but impossible to perform without
                the assistance of our support.<br>
                BimmerTech is not responsible for errors in software uploading by customers due
                to uploading the incorrect version.<br>
                After this step, replacement under warranty cannot be considered.
            </div>

        </form>
    </div>

    <!-- Bottom card -->
    <div class="bottom-card">
        <a class="shop-btn" href="https://bimmer-tech.net/" target="_blank">
            Go back to the shop
        </a>
        <p class="legal-text">
            BMW and MINI are registered trademarks of Bayerische Motoren Werke AG.
            BimmerTech is not affiliated with BMW AG in any way, and is not authorized by
            BMW AG to act as an official distributor or representative.
        </p>
    </div>

</div>

<!-- Modal: "What is my current software?" -->
<div class="modal-overlay" id="info-modal">
    <div class="modal-box">
        <div class="modal-header">
            <button class="modal-close" id="close-modal" aria-label="Close">&times;</button>
        </div>
        <img src="/images/mmi_software_version.jpg"
             alt="How to find your software version in MMI settings"
             onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
        <p style="display:none;padding:32px;font-size:14px;text-align:center;">
            Go to MMI settings &rarr; System &rarr; System/firmware version
        </p>
    </div>
</div>

<script>
(function () {
    'use strict';

    var formCard  = document.getElementById('form-card');
    var result    = document.getElementById('result');
    var modal     = document.getElementById('info-modal');

    // ── Modal open / close ────────────────────────────────────────────────
    document.getElementById('open-modal').addEventListener('click', function () {
        modal.classList.add('open');
    });
    document.getElementById('close-modal').addEventListener('click', function () {
        modal.classList.remove('open');
    });
    modal.addEventListener('click', function (e) {
        if (e.target === modal) modal.classList.remove('open');
    });

    // ── Form submit ───────────────────────────────────────────────────────
    document.getElementById('sw-form').addEventListener('submit', function (e) {
        e.preventDefault();

        var version   = document.getElementById('version').value.trim();
        var hwVersion = document.getElementById('hwVersion').value.trim();

        // Client-side validation (mirrors the Vue :rules="[rules.required]")
        var ok = true;

        if (!version) {
            document.getElementById('version-err').classList.add('show');
            ok = false;
        } else {
            document.getElementById('version-err').classList.remove('show');
        }

        if (!hwVersion) {
            document.getElementById('hwVersion-err').classList.add('show');
            ok = false;
        } else {
            document.getElementById('hwVersion-err').classList.remove('show');
        }

        if (!ok) return;

        // Reset result, show loading
        result.style.display = 'none';
        result.innerHTML = '';
        formCard.classList.add('loading');
        document.getElementById('check-btn').disabled = true;

        // Build POST body (application/x-www-form-urlencoded to match PHP $_POST)
        var body = new URLSearchParams({
            version:    version,
            mcuVersion: document.getElementById('mcuVersion').value || '',
            hwVersion:  hwVersion
        });

        fetch('/api/carplay/software/version', {
            method:  'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body:    body.toString()
        })
        .then(function (r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
        })
        .then(function (data) { renderResult(data); })
        .catch(function () {
            renderResult({ msg: 'Failed to fetch software details. Please try again.' });
        })
        .finally(function () {
            formCard.classList.remove('loading');
            document.getElementById('check-btn').disabled = false;
        });
    });

    // ── Render API response (identical behaviour to Vue template) ─────────
    function renderResult(data) {
        var html = '';

        if (typeof data.versionExist === 'undefined') {
            // Validation-only response (version/hwVersion required)
            html = '<div class="alert alert-error"><p style="color:red;margin:0;">'
                 + esc(data.msg) + '</p></div>';

        } else if (data.versionExist) {
            // Success — up to date or update available
            var links = '';
            if (data.st) {
                links += ' <a class="download-link" href="' + esc(data.st)
                       + '" target="_blank">ST Version</a>';
            }
            if (data.gd) {
                links += ' <a class="download-link" href="' + esc(data.gd)
                       + '" target="_blank">GD Version</a>';
            }
            html = '<div class="alert alert-success">'
                 + '<p style="color:#389e0d !important;margin:0;">'
                 + esc(data.msg) + links + '</p></div>';

        } else {
            // Not found / error
            html = '<div class="alert alert-error"><p style="color:red;margin:0;">'
                 + esc(data.msg) + '</p></div>';
        }

        result.innerHTML = html;
        result.style.display = '';
    }

    function esc(str) {
        return String(str || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }
}());
</script>

</body>
</html>
